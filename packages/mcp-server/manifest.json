{
  "dxt_version": "0.2",
  "name": "@dinari/api-sdk-mcp",
  "version": "0.14.0",
  "description": "The official MCP Server for the Dinari API",
  "author": {
    "name": "Dinari",
    "email": "hello@dinari.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dinaricrypto/dinari-api-sdk-typescript.git"
  },
  "homepage": "https://github.com/dinaricrypto/dinari-api-sdk-typescript/tree/main/packages/mcp-server#readme",
  "documentation": "https://docs.dinari.com/",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/index.js"
      ],
      "env": {
        "DINARI_API_KEY_ID": "${user_config.DINARI_API_KEY_ID}",
        "DINARI_API_SECRET_KEY": "${user_config.DINARI_API_SECRET_KEY}"
      }
    }
  },
  "user_config": {
    "DINARI_API_KEY_ID": {
      "title": "api_key_id",
      "description": "The API key ID provided on the [Partners Dashboard](https://partners.dinari.com).",
      "required": true,
      "type": "string"
    },
    "DINARI_API_SECRET_KEY": {
      "title": "api_secret_key",
      "description": "API Secret Key that is only shown once at API Key creation.",
      "required": true,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": [
    "api"
  ]
}
